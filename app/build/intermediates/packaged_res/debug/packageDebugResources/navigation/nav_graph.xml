<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Onboarding -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.frenchquest.ui.onboarding.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_placement"
            app:destination="@id/placementTestFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/placementTestFragment"
        android:name="com.frenchquest.ui.onboarding.PlacementTestFragment"
        android:label="Placement Test">
        <action
            android:id="@+id/action_placement_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/placementTestFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Main Tabs -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.frenchquest.ui.home.HomeFragment"
        android:label="@string/nav_home">
        <action android:id="@+id/action_home_to_wordMatch" app:destination="@id/wordMatchFragment" />
        <action android:id="@+id/action_home_to_flashcard" app:destination="@id/flashcardFragment" />
        <action android:id="@+id/action_home_to_fillGap" app:destination="@id/fillGapFragment" />
        <action android:id="@+id/action_home_to_listenTap" app:destination="@id/listenTapFragment" />
        <action android:id="@+id/action_home_to_dialogue" app:destination="@id/dialogueFragment" />
        <action android:id="@+id/action_home_to_pronounce" app:destination="@id/pronounceFragment" />
        <action android:id="@+id/action_home_to_quizBlitz" app:destination="@id/quizBlitzFragment" />
        <action android:id="@+id/action_home_to_bonus" app:destination="@id/bonusFragment" />
    </fragment>

    <fragment
        android:id="@+id/progressFragment"
        android:name="com.frenchquest.ui.progress.ProgressFragment"
        android:label="@string/nav_progress" />

    <!-- Mini-Games -->
    <fragment
        android:id="@+id/wordMatchFragment"
        android:name="com.frenchquest.ui.game.WordMatchGameFragment"
        android:label="Word Match" />

    <fragment
        android:id="@+id/flashcardFragment"
        android:name="com.frenchquest.ui.game.FlashcardGameFragment"
        android:label="Flashcards" />

    <fragment
        android:id="@+id/fillGapFragment"
        android:name="com.frenchquest.ui.game.FillGapGameFragment"
        android:label="Fill the Gap" />

    <fragment
        android:id="@+id/listenTapFragment"
        android:name="com.frenchquest.ui.game.ListenTapGameFragment"
        android:label="Listen &amp; Tap" />

    <fragment
        android:id="@+id/dialogueFragment"
        android:name="com.frenchquest.ui.game.DialogueGameFragment"
        android:label="Dialogue" />

    <fragment
        android:id="@+id/pronounceFragment"
        android:name="com.frenchquest.ui.game.PronounceGameFragment"
        android:label="Pronounce" />

    <fragment
        android:id="@+id/quizBlitzFragment"
        android:name="com.frenchquest.ui.game.QuizBlitzFragment"
        android:label="Quiz Blitz" />

    <fragment
        android:id="@+id/bonusFragment"
        android:name="com.frenchquest.ui.game.BonusRoundFragment"
        android:label="Bonus Round" />

</navigation>
